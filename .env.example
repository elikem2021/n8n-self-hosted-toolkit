## Public hostname (Caddy will auto-issue Let's Encrypt cert for this)
N8N_HOST=n8n.your-domain.com

## Encryption key — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

## Basic auth on the n8n admin UI
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

## Postgres
POSTGRES_USER=n8n
POSTGRES_PASSWORD=
POSTGRES_DB=n8n

## Redis (queue mode)
REDIS_PASSWORD=

## Timezone
TZ=America/Toronto

## S3-compatible backup target (used by backup/backup.sh)
S3_BACKUP_BUCKET=
S3_BACKUP_REGION=us-east-1
S3_BACKUP_ACCESS_KEY=
S3_BACKUP_SECRET_KEY=
S3_BACKUP_ENDPOINT=
